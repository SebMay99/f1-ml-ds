import fastf1
import pandas as pd
from typing import Generator

import fastf1.core

# Activate local cache
fastf1.Cache.enable_cache('./etl/cache/') # Avoid downloading the same data multiple times

def load_session_results(year: int, session_type: str) -> Generator[tuple[int, fastf1.core.Session], None, None]:
    """Yields (round_number, session) pairs for a given year and session type."""

    schedule = fastf1.get_event_schedule(year, include_testing=False)
    for round_num in range(1, len(schedule) + 1):
        try:
            session = fastf1.get_session(year, round_num, session_type)
            session.load()

            yield round_num, session

        except Exception as e:
            print(f"Could not load round {round_num}, year {year}, session {session_type}: {e}")
            continue

def fetch_race_results(year: int) -> pd.DataFrame:
    """Fetches race results for a given year and returns a DataFrame."""

    frames = []

    for round_num, session in load_session_results(year, 'R'):
        results = session.results[['DriverNumber','Abbreviation','FullName','TeamName','GridPosition','Position','Status']].copy()
        results['year'] = year
        results['round_number'] = round_num
        results['circuit'] = session.event['Location']
        frames.append(results)

    return pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()

def fetch_qualifying_results(year: int) -> pd.DataFrame:
    """Fetches qualifying results for a given year and returns a DataFrame."""

    frames = []

    for round_num, session in load_session_results(year, 'Q'):
        results = session.results[['DriverNumber', 'Abbreviation', 'Q1', 'Q2', 'Q3', 'Position']].copy()
        results = results.rename(columns={'Position': 'QualyPosition'})
        results['year'] = year
        results['round_number'] = round_num
        results['circuit'] = session.event['Location']
        frames.append(results)

    return pd.concat(frames, ignore_index=True) if frames else pd.DataFrame()

print(fetch_race_results(2023).head())
print(fetch_qualifying_results(2023).head())